{
  "name": "upgrade-interactive",
  "version": "1.3.0",
  "description": "An interactive dependency upgrader for npm projects, inspired by `yarn upgrade-interactive` (Yarn Berry / Yarn 4), with built-in vulnerability warnings.",
  "type": "module",
  "bin": {
    "upgrade-interactive": "src/cli.js",
    "nui": "src/cli.js"
  },
  "main": "./src/cli.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pablobbb/upgrade-interactive.git"
  },
  "homepage": "https://github.com/pablobbb/upgrade-interactive#readme",
  "bugs": {
    "url": "https://github.com/pablobbb/upgrade-interactive/issues"
  },
  "scripts": {
    "test": "node --test \"test/unit/**/*.test.mjs\"",
    "test:integration": "node test/app.test.mjs",
    "test:all": "npm run test && npm run test:integration"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src"
  ],
  "keywords": [
    "npm",
    "yarn",
    "upgrade-interactive",
    "upgrade",
    "update",
    "dependencies",
    "devdependencies",
    "outdated",
    "npm-outdated",
    "dependency-management",
    "package-manager",
    "semver",
    "vulnerability",
    "vulnerabilities",
    "audit",
    "npm-audit",
    "security",
    "overrides",
    "cli",
    "tui",
    "terminal",
    "interactive"
  ],
  "license": "MIT",
  "dependencies": {
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "ink-testing-library": "^4.0.0"
  }
}
